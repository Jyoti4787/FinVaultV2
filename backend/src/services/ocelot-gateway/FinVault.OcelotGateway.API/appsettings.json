{
  "Jwt": {
    "Secret": "FinVault-Super-Secret-Key-Must-Be-32-Chars!!",
    "Issuer": "https://finvault.io",
    "Audiences": ["finvault-identity", "finvault-card", "finvault-payment", "finvault-user"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SwaggerEndPoints": [
    {
      "Key": "identity",
      "TransformByOcelotConfig": false,
      "Config": [ { "Name": "Identity Service", "Version": "v1", "Url": "http://identity-service:8080/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "cards",
      "TransformByOcelotConfig": false,
      "Config": [ { "Name": "Card Service", "Version": "v1", "Url": "http://card-service:8080/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "payments",
      "TransformByOcelotConfig": false,
      "Config": [ { "Name": "Payment Service", "Version": "v1", "Url": "http://payment-service:8080/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "notifications",
      "TransformByOcelotConfig": false,
      "Config": [ { "Name": "Notification Service", "Version": "v1", "Url": "http://notification-service:8080/swagger/v1/swagger.json" } ]
    }
  ]
}
