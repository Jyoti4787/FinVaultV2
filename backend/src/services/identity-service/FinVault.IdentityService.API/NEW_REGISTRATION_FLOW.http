### FinVault Identity Service - New Registration Flow
### Base URL
@baseUrl = http://localhost:5232/api/identity/auth

###############################################################################
# NEW REGISTRATION FLOW (2 Steps)
###############################################################################

### Step 1: Register User - Sends OTP to Email
# This endpoint stores user data temporarily and sends OTP via email
POST {{baseUrl}}/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "SecurePass123",
  "firstName": "John",
  "lastName": "Doe"
}

# Expected Response:
# {
#   "success": true,
#   "data": {
#     "message": "Registration initiated. A verification code has been sent to your email. Valid for 15 minutes."
#   }
# }

###

### Step 2: Verify OTP and Complete Registration
# After receiving OTP in email, verify it to create the actual user account
POST {{baseUrl}}/register/verify
Content-Type: application/json

{
  "email": "test@example.com",
  "code": "123456"
}

# Expected Response (Success):
# {
#   "success": true,
#   "data": {
#     "success": true,
#     "message": "Registration successful! Welcome to FinVault.",
#     "userId": "guid-here",
#     "email": "test@example.com"
#   }
# }

# Expected Response (Invalid OTP):
# {
#   "success": false,
#   "message": "Invalid OTP code."
# }

###############################################################################
# NOTES
###############################################################################
# 
# 1. User data (email, password, firstName, lastName) is stored in PendingRegistration
# 2. OTP is sent via notification-service to the user's email
# 3. OTP expires in 15 minutes
# 4. User account is only created after successful OTP verification
# 5. Check Docker logs for DEV OTP code: docker logs finvault-identity --tail 50
# 6. Look for: ">>> DEV REGISTRATION OTP <<< Email: ... | Code: ..."
#
###############################################################################
